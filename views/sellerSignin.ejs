<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Seller Sign In - SellerHub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        html { height: 100%; }
        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
            min-height: 100dvh;
            font-family: 'Inter', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            padding: 0.75rem;
        }
        .auth-container {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex: 1;
            padding: 3.5rem 0 0.5rem;
        }
        .auth-card {
            background: rgba(255, 255, 255, 0.97);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            overflow: hidden;
            width: 100%;
            max-width: 420px;
            animation: slideIn 0.4s ease-out;
        }
        .auth-card-body { padding: 2rem 1.75rem; }
        .auth-header { text-align: center; margin-bottom: 1.5rem; }
        .auth-header h2 {
            font-size: 1.6rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 0.4rem;
            letter-spacing: -0.5px;
        }
        .auth-header p { color: #64748b; font-size: 0.9rem; font-weight: 500; }
        .seller-badge {
            display: inline-block;
            background: linear-gradient(135deg, #f59e0b, #d97706);
            color: white;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }
        .form-group { margin-bottom: 1rem; }
        .form-label {
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 0.4rem;
            display: block;
            font-size: 0.9rem;
        }
        .form-control {
            width: 100%;
            border-radius: 10px;
            padding: 0.75rem 0.9rem;
            border: 2px solid #e2e8f0;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
        }
        .form-control:focus {
            border-color: #f59e0b;
            box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.15);
            outline: none;
        }
        .form-control::placeholder { color: #94a3b8; }
        .input-group { display: flex; align-items: stretch; }
        .input-group .form-control { border-radius: 10px 0 0 10px; margin: 0; }
        .input-group .btn-toggle {
            border-radius: 0 10px 10px 0;
            border: 2px solid #e2e8f0;
            border-left: none;
            background: white;
            color: #64748b;
            font-size: 1.1rem;
            padding: 0.75rem 0.9rem;
            min-width: 44px;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .input-group .btn-toggle:hover { background: #f8fafc; color: #334155; }
        .btn-signin {
            background: linear-gradient(135deg, #f59e0b, #d97706);
            border: none;
            border-radius: 10px;
            padding: 0.8rem 1.5rem;
            color: white;
            font-weight: 700;
            font-size: 0.95rem;
            width: 100%;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 0.75rem;
            font-family: 'Inter', sans-serif;
        }
        .btn-signin:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px rgba(245, 158, 11, 0.3);
        }
        .btn-signin:active { transform: translateY(0); }
        .btn-signin:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }
        .forgot-link { text-align: center; margin-bottom: 1rem; }
        .forgot-link a {
            color: #f59e0b;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.85rem;
            transition: color 0.3s ease;
        }
        .forgot-link a:hover { color: #d97706; }
        .divider {
            display: flex;
            align-items: center;
            margin: 1rem 0;
            color: #94a3b8;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e2e8f0;
        }
        .divider span { padding: 0 0.75rem; font-size: 0.8rem; font-weight: 600; }
        .btn-google {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            width: 100%;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            padding: 0.8rem 1.5rem;
            background: white;
            color: #1e293b;
            font-weight: 600;
            font-size: 0.9rem;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
            margin-bottom: 1rem;
        }
        .btn-google:hover {
            border-color: #cbd5e1;
            background: #f8fafc;
            transform: translateY(-1px);
        }
        .signup-link {
            text-align: center;
            margin-top: 1rem;
            color: #64748b;
            font-size: 0.85rem;
        }
        .signup-link a {
            color: #f59e0b;
            text-decoration: none;
            font-weight: 700;
            transition: color 0.3s ease;
        }
        .signup-link a:hover { color: #d97706; }
        .alert {
            border-radius: 10px;
            padding: 0.85rem;
            margin-bottom: 1rem;
            border: none;
            font-weight: 500;
            font-size: 0.9rem;
        }
        .alert-danger { background-color: #fee2e2; color: #991b1b; }
        .back-link {
            position: absolute;
            top: 1rem;
            left: 1rem;
            color: #94a3b8;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }
        .back-link:hover { color: white; }
        @keyframes slideIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .spinner-border {
            display: inline-block;
            width: 1rem;
            height: 1rem;
            vertical-align: text-bottom;
            border: 2px solid currentColor;
            border-right-color: transparent;
            border-radius: 50%;
            animation: spinner-border 0.75s linear infinite;
        }
        @keyframes spinner-border { to { transform: rotate(360deg); } }
        @media (max-width: 576px) {
            body { padding: 0.5rem; justify-content: flex-start; padding-top: 3rem; padding-bottom: 0.75rem; }
            .auth-container { align-items: flex-start; padding: 0; }
            .auth-card { max-width: 100%; border-radius: 14px; }
            .auth-card-body { padding: 1.5rem 1.25rem; }
            .auth-header h2 { font-size: 1.4rem; }
        }
    </style>
</head>
<body>
    <a href="/" class="back-link">← Back to Home</a>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-card-body">
                <div class="auth-header">
                    <span class="seller-badge">🛒 SELLER PORTAL</span>
                    <h2>Welcome Back, Seller</h2>
                    <p>Sign in to manage your business</p>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>

                <form id="sellerSigninForm">
                    <div class="form-group">
                        <label class="form-label">Email Address</label>
                        <input type="email" id="email" name="email" class="form-control" placeholder="you@business.com" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Password</label>
                        <div class="input-group">
                            <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required>
                            <button type="button" class="btn-toggle" id="togglePassword">👁️</button>
                        </div>
                    </div>

                    <button type="submit" class="btn-signin" id="submitBtn">
                        Sign In to Dashboard
                    </button>
                </form>

                <div class="forgot-link">
                    <a href="#" id="forgotLink">Forgot Password?</a>
                </div>

                <div class="divider"><span>OR</span></div>

                <a href="/seller/auth/google" class="btn-google">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" 
                         width="20" height="20" alt="Google">
                    Continue with Google
                </a>

                <p class="signup-link">
                    New to selling? 
                    <a href="/seller/signup">Register as Seller</a>
                </p>
            </div>
        </div>
    </div>

    <script>
        const toggleBtn = document.getElementById('togglePassword');
        toggleBtn.addEventListener('click', function () {
            const passwordField = document.getElementById('password');
            passwordField.type = passwordField.type === 'password' ? 'text' : 'password';
            this.textContent = passwordField.type === 'password' ? '👁️' : '🙈';
        });

        document.getElementById('sellerSigninForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span class="spinner-border me-2"></span>Signing In...`;

            const data = {
                email: document.getElementById('email').value.trim(),
                password: document.getElementById('password').value
            };

            try {
                const res = await fetch('/seller/signin', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();

                if (result.success) {
                    window.location.href = result.redirect || "/seller/dashboard";
                } else {
                    alert(result.message || "Invalid email or password");
                    submitBtn.disabled = false;
                    submitBtn.textContent = "Sign In to Dashboard";
                }
            } catch (err) {
                alert("Something went wrong. Please try again.");
                submitBtn.disabled = false;
                submitBtn.textContent = "Sign In to Dashboard";
            }
        });

        document.getElementById('forgotLink').addEventListener('click', async function (e) {
            e.preventDefault();
            const email = prompt("Enter your registered email address:");
            if (!email) return;

            try {
                const res = await fetch('/seller/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });
                const data = await res.json();
                alert(data.message);
            } catch (err) {
                alert("Failed to send reset link");
            }
        });
    </script>
</body>
</html>
