<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Become a Seller - SellerHub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        html { height: 100%; }
        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
            min-height: 100dvh;
            font-family: 'Inter', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            padding: 0.75rem;
        }
        .auth-container {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex: 1;
            padding: 3.5rem 0 0.5rem;
        }
        .auth-card {
            background: rgba(255, 255, 255, 0.97);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            overflow: hidden;
            width: 100%;
            max-width: 520px;
            animation: slideIn 0.4s ease-out;
            max-height: 85vh;
            overflow-y: auto;
        }
        .auth-card-body { padding: 1.75rem 1.5rem; }
        .auth-header { text-align: center; margin-bottom: 1.25rem; }
        .auth-header h2 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 0.3rem;
            letter-spacing: -0.5px;
        }
        .auth-header p { color: #64748b; font-size: 0.85rem; font-weight: 500; }
        .form-group { margin-bottom: 0.85rem; }
        .form-label {
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 0.35rem;
            display: block;
            font-size: 0.85rem;
        }
        .form-control {
            width: 100%;
            border-radius: 10px;
            padding: 0.7rem 0.85rem;
            border: 2px solid #e2e8f0;
            font-size: 16px;
            font-weight: 500;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
        }
        .form-control:focus {
            border-color: #f59e0b;
            box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.15);
            outline: none;
        }
        .form-control::placeholder { color: #94a3b8; }
        .input-group { display: flex; align-items: stretch; }
        .input-group .form-control { border-radius: 10px 0 0 10px; margin: 0; }
        .input-group .btn-toggle {
            border-radius: 0 10px 10px 0;
            border: 2px solid #e2e8f0;
            border-left: none;
            background: white;
            color: #64748b;
            font-size: 1.1rem;
            padding: 0.7rem 0.85rem;
            min-width: 44px;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .input-group .btn-toggle:hover { background: #f8fafc; color: #334155; }
        .otp-container { margin-bottom: 0.85rem; }
        .otp-inputs {
            display: flex;
            gap: 0.4rem;
            margin-bottom: 0.75rem;
            justify-content: center;
        }
        .otp-box {
            width: 40px;
            height: 46px;
            font-size: 1.2rem;
            font-weight: 700;
            text-align: center;
            border-radius: 8px;
            border: 2px solid #e2e8f0;
            background: white;
            color: #1e293b;
            transition: all 0.3s ease;
            font-family: 'Inter', monospace;
        }
        .otp-box:focus {
            border-color: #f59e0b;
            box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.15);
            outline: none;
        }
        .btn-send-otp {
            background: linear-gradient(135deg, #f59e0b, #d97706);
            border: none;
            border-radius: 10px;
            padding: 0.65rem 1.5rem;
            color: white;
            font-weight: 700;
            font-size: 0.85rem;
            width: 100%;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 0.5rem;
            font-family: 'Inter', sans-serif;
        }
        .btn-send-otp:hover:not(:disabled) {
            transform: translateY(-1px);
            box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);
        }
        .btn-send-otp:disabled { opacity: 0.6; cursor: not-allowed; }
        .btn-signup {
            background: linear-gradient(135deg, #f59e0b, #d97706);
            border: none;
            border-radius: 10px;
            padding: 0.8rem 1.5rem;
            color: white;
            font-weight: 700;
            font-size: 0.95rem;
            width: 100%;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
        }
        .btn-signup:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px rgba(245, 158, 11, 0.3);
        }
        .btn-signup:active { transform: translateY(0); }
        .btn-signup:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }
        .divider {
            display: flex;
            align-items: center;
            margin: 1rem 0;
            color: #94a3b8;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e2e8f0;
        }
        .divider span { padding: 0 0.75rem; font-size: 0.8rem; font-weight: 600; }
        .btn-google {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            width: 100%;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            padding: 0.8rem 1.5rem;
            background: white;
            color: #1e293b;
            font-weight: 600;
            font-size: 0.9rem;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
            margin-bottom: 1rem;
        }
        .btn-google:hover {
            border-color: #cbd5e1;
            background: #f8fafc;
            transform: translateY(-1px);
        }
        .signin-link {
            text-align: center;
            margin-top: 1rem;
            color: #64748b;
            font-size: 0.85rem;
        }
        .signin-link a {
            color: #f59e0b;
            text-decoration: none;
            font-weight: 700;
            transition: color 0.3s ease;
        }
        .signin-link a:hover { color: #d97706; }
        .alert {
            border-radius: 10px;
            padding: 0.85rem;
            margin-bottom: 1rem;
            border: none;
            font-weight: 500;
            font-size: 0.9rem;
        }
        .alert-danger { background-color: #fee2e2; color: #991b1b; }
        .section-title {
            font-size: 0.9rem;
            font-weight: 700;
            color: #f59e0b;
            margin: 1.25rem 0 0.75rem 0;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #e2e8f0;
        }
        .form-row { display: flex; gap: 0.75rem; }
        .form-row .form-group { flex: 1; }
        .back-link {
            position: absolute;
            top: 1rem;
            left: 1rem;
            color: #94a3b8;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }
        .back-link:hover { color: white; }
        @keyframes slideIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .spinner-border {
            display: inline-block;
            width: 1rem;
            height: 1rem;
            vertical-align: text-bottom;
            border: 2px solid currentColor;
            border-right-color: transparent;
            border-radius: 50%;
            animation: spinner-border 0.75s linear infinite;
        }
        @keyframes spinner-border { to { transform: rotate(360deg); } }
        @media (max-width: 576px) {
            body { padding: 0.5rem; justify-content: flex-start; padding-top: 3rem; padding-bottom: 0.75rem; }
            .auth-container { align-items: flex-start; padding: 0; }
            .auth-card { max-width: 100%; border-radius: 14px; }
            .auth-card-body { padding: 1.5rem 1.25rem; }
            .auth-header h2 { font-size: 1.35rem; }
            .otp-box { width: 36px; height: 42px; font-size: 1.1rem; }
            .otp-inputs { gap: 0.3rem; }
            .form-row { flex-direction: column; gap: 0; }
        }
    </style>
</head>
<body>
    <a href="/" class="back-link">← Back to Home</a>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-card-body">
                <div class="auth-header">
                    <h2>🛒 Become a Seller</h2>
                    <p>Register your business on SellerHub</p>
                </div>

                <a href="/seller/auth/google" class="btn-google">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" 
                         width="20" height="20" alt="Google">
                    Sign up with Google
                </a>

                <div class="divider"><span>OR</span></div>

                <form id="sellerSignupForm">
                    <div class="section-title">👤 Personal Information</div>
                    
                    <div class="form-group">
                        <label class="form-label">Full Name *</label>
                        <input type="text" id="fullName" name="fullName" class="form-control" placeholder="John Doe" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Email Address *</label>
                        <input type="email" id="email" name="email" class="form-control" placeholder="you@example.com" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Password *</label>
                        <div class="input-group">
                            <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required minlength="6">
                            <button type="button" class="btn-toggle" id="togglePassword">👁️</button>
                        </div>
                    </div>

                    <div class="otp-container">
                        <label class="form-label">Verification Code (OTP) *</label>
                        <div class="otp-inputs" id="otpContainer">
                            <input type="text" maxlength="1" class="otp-box" data-index="0">
                            <input type="text" maxlength="1" class="otp-box" data-index="1">
                            <input type="text" maxlength="1" class="otp-box" data-index="2">
                            <input type="text" maxlength="1" class="otp-box" data-index="3">
                            <input type="text" maxlength="1" class="otp-box" data-index="4">
                            <input type="text" maxlength="1" class="otp-box" data-index="5">
                        </div>
                        <button type="button" class="btn-send-otp" id="sendOtpBtn">Send OTP</button>
                        <input type="hidden" name="otp" id="hiddenOtp">
                    </div>

                    <div class="section-title">🏢 Business Details</div>

                    <div class="form-group">
                        <label class="form-label">Business Name</label>
                        <input type="text" id="businessName" name="businessName" class="form-control" placeholder="Your Business Name">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Business Address</label>
                        <input type="text" id="businessAddress" name="businessAddress" class="form-control" placeholder="Full Address">
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Phone Number</label>
                            <input type="tel" id="phoneNumber" name="phoneNumber" class="form-control" placeholder="+91 98765 43210">
                        </div>
                        <div class="form-group">
                            <label class="form-label">GST Number</label>
                            <input type="text" id="gstNumber" name="gstNumber" class="form-control" placeholder="22AAAAA0000A1Z5">
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">PAN Number</label>
                            <input type="text" id="panNumber" name="panNumber" class="form-control" placeholder="ABCDE1234F">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Bank Account Number</label>
                            <input type="text" id="bankAccountNumber" name="bankAccountNumber" class="form-control" placeholder="Account Number">
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">IFSC Code</label>
                        <input type="text" id="ifscCode" name="ifscCode" class="form-control" placeholder="SBIN0001234">
                    </div>

                    <button type="submit" class="btn-signup" id="submitBtn">
                        Create Seller Account
                    </button>
                </form>

                <p class="signin-link">
                    Already a seller? 
                    <a href="/seller/signin">Sign In</a>
                </p>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('togglePassword').addEventListener('click', function () {
            const pw = document.getElementById('password');
            pw.type = pw.type === 'password' ? 'text' : 'password';
            this.textContent = pw.type === 'password' ? '👁️' : '🙈';
        });

        const otpInputs = document.querySelectorAll('.otp-box');
        otpInputs.forEach((input, index) => {
            input.addEventListener('input', () => {
                if (input.value.length === 1 && index < 5) otpInputs[index + 1].focus();
                updateHiddenOtp();
            });
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && input.value === '' && index > 0) otpInputs[index - 1].focus();
            });
        });

        function updateHiddenOtp() {
            let otp = '';
            otpInputs.forEach(box => otp += box.value);
            document.getElementById('hiddenOtp').value = otp;
        }

        document.getElementById('sendOtpBtn').addEventListener('click', async function() {
            const email = document.getElementById('email').value.trim();
            if (!email) return alert("Please enter your email first!");
            this.disabled = true;
            this.textContent = "Sending OTP...";
            try {
                const res = await fetch('/seller/send-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });
                const data = await res.json();
                if (data.success) {
                    alert(`✅ OTP sent to ${email}`);
                    this.textContent = "Resend OTP";
                    setTimeout(() => this.disabled = false, 30000);
                } else {
                    alert(data.message || "Failed to send OTP");
                    this.disabled = false;
                    this.textContent = "Send OTP";
                }
            } catch (err) {
                alert("Failed to send OTP");
                this.disabled = false;
                this.textContent = "Send OTP";
            }
        });

        document.getElementById('sellerSignupForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span class="spinner-border me-2"></span>Creating...`;
            const formData = new FormData(this);
            const data = Object.fromEntries(formData.entries());
            try {
                const res = await fetch('/seller/signup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                if (result.success) {
                    alert("🎉 Seller account created successfully!");
                    window.location.href = result.redirect || "/seller/dashboard";
                } else {
                    alert(result.message);
                    submitBtn.disabled = false;
                    submitBtn.textContent = "Create Seller Account";
                }
            } catch (err) {
                alert("Something went wrong");
                submitBtn.disabled = false;
                submitBtn.textContent = "Create Seller Account";
            }
        });
    </script>
</body>
</html>
